{
  "name": "grove-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter tauri-tray tauri:dev",
