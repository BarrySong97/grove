{
  "name": "tauri-tray",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "lint": "oxlint . --deny-warnings --no-error-on-unmatched-pattern",
    "format": "oxfmt --write . --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check . --no-error-on-unmatched-pattern",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build": "tauri build",
    "packages": "pnpm tauri:build && (osascript -e 'quit app \"Grove\"' || true) && rm -rf \"/Applications/Grove.app\" && ditto \"src-tauri/target/release/bundle/macos/Grove.app\" \"/Applications/Grove.app\" && open \"/Applications/Grove.app\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "catalog:",
    "@heroui/styles": "catalog:",
    "@tanstack/react-query": "^5.101.0",
    "@tauri-apps/api": "^2.0.0",
    "i18next": "^26.3.1",
    "jotai": "^2.20.1",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.14.0"
}
