{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Grove",
  "version": "0.2.6",
  "identifier": "com.4real.grove",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Grove",
        "width": 326,
        "height": 720,
        "visible": false,
        "skipTaskbar": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "shadow": true,
        "windowEffects": {
          "effects": [
            "popover"
          ],
          "state": "active",
          "radius": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BarrySong97/grove/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGMzI3MDRGOUUwNEEzRTAKUldUZ293U2VUM0F5WDQ1cHQzbEpsU2VndFc5UHNCUytzUXNRZGREY3RWSzlFL2NkZ3FDcWNTeW0K"
    }
  }
}
