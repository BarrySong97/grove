{
  "sourceExts": [".ts", ".tsx", ".rs", ".css"],
  "sourceRoots": ["src/app", "src/modules", "src/shared", "src-tauri/src"],
  "ignoreDirs": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "target",
    "gen",
    ".next",
    "out",
    "coverage",
    ".turbo",
    ".cache",
    "vendor",
    ".venv",
    "venv",
    "__pycache__",
    ".idea",
    ".vscode",
    "templates"
  ],
  "nonModuleDirs": ["app", "scripts", "test", "tests", "__tests__", "spec", "bin", "config", "public", "assets", "types", "typings", "migrations"],
  "headerMarker": "@purpose",
  "headerScanLines": 20,
  "docsDir": "docs"
}
