{
  "sourceExts": [".ts", ".tsx", ".rs", ".css"],
  "sourceRoots": [
    "apps/desktop/src/app",
    "apps/desktop/src/modules",
    "apps/desktop/src/shared",
    "apps/desktop/src-tauri/src",
    "apps/desktop/src/main.tsx",
    "apps/desktop/src/vite-env.d.ts",
    "apps/desktop/vite.config.ts",
    "apps/desktop/src-tauri/build.rs"
  ],
  "ignoreDirs": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "target",
    "gen",
    ".next",
    "out",
    "coverage",
    ".turbo",
    ".cache",
    "vendor",
    ".venv",
    "venv",
    "__pycache__",
    ".idea",
    ".vscode",
    "templates"
  ],
  "nonModuleDirs": [
    "app",
    "scripts",
    "test",
    "tests",
    "__tests__",
    "spec",
    "bin",
    "config",
    "public",
    "assets",
    "types",
    "typings",
    "migrations"
  ],
  "headerMarker": "@purpose",
  "headerScanLines": 20,
  "docsDir": "docs"
}
